<div class="mt-5">
       <h2 class="h2">Tìm kiếm bài viết</h2>
       <form action="/search" method="GET" class="mt-4">
           <div class="form-group">
               <label for="search-input">Từ khóa</label>
               <input type="text" name="q" class="form-control" id="search-input" placeholder="Nhập từ khóa...">
           </div>
           <div class="form-group mt-3">
       <label for="search-type">Loại tìm kiếm</label>
       <select name="type" class="form-control" id="search-type">
           <option value="post">Bài viết</option>
           <option value="author">Tác giả</option>
       </select>
   </div>
           <button type="submit" class="btn btn-primary mt-2">Tìm kiếm</button>
       </form>
   </div>